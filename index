<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Draw a Perfect Circle</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: #0a0a0a;
color: #e8e8e8;
font-family: ‘Courier New’, monospace;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
min-height: 100vh;
overflow: hidden;
user-select: none;
}

h1 {
font-size: 1.4rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: #888;
margin-bottom: 6px;
font-weight: 400;
}

#subtitle {
font-size: 0.72rem;
color: #444;
letter-spacing: 0.15em;
margin-bottom: 16px;
}

/* Toggle row */
#toggles {
display: flex;
gap: 14px;
margin-bottom: 16px;
}

.toggle-btn {
background: none;
border: 1px solid #2a2a2a;
color: #444;
padding: 5px 14px;
font-family: ‘Courier New’, monospace;
font-size: 0.68rem;
letter-spacing: 0.18em;
text-transform: uppercase;
cursor: pointer;
border-radius: 2px;
transition: all 0.2s;
}

.toggle-btn.on {
border-color: #555;
color: #bbb;
background: #161616;
}

.toggle-btn:hover {
border-color: #666;
color: #ccc;
}

/* Canvas */
#canvas-wrapper {
position: relative;
width: 420px;
height: 420px;
}

canvas {
border: 1px solid #222;
border-radius: 4px;
cursor: crosshair;
display: block;
touch-action: none;
}

/* Score */
#score-display {
margin-top: 18px;
text-align: center;
min-height: 90px;
}

#score-number {
font-size: 3.5rem;
font-weight: 700;
color: #fff;
letter-spacing: -0.02em;
transition: color 0.3s;
}

#score-label {
font-size: 0.7rem;
letter-spacing: 0.25em;
color: #555;
text-transform: uppercase;
margin-top: 2px;
}

#score-grade {
font-size: 0.85rem;
letter-spacing: 0.1em;
color: #777;
margin-top: 6px;
min-height: 1.2em;
}

#assist-note {
font-size: 0.65rem;
letter-spacing: 0.08em;
color: #555;
margin-top: 5px;
min-height: 1em;
font-style: italic;
}

#instructions {
font-size: 0.72rem;
color: #444;
letter-spacing: 0.08em;
margin-top: 14px;
}

#btn-retry {
margin-top: 12px;
background: none;
border: 1px solid #333;
color: #666;
padding: 8px 28px;
font-family: ‘Courier New’, monospace;
font-size: 0.75rem;
letter-spacing: 0.2em;
text-transform: uppercase;
cursor: pointer;
border-radius: 2px;
transition: all 0.2s;
display: none;
}

#btn-retry:hover {
border-color: #888;
color: #ccc;
}
</style>

</head>
<body>

<h1>Draw a Perfect Circle</h1>
<p id="subtitle">mouse or touch · release to score</p>

<div id="toggles">
  <button class="toggle-btn on" id="btn-grid">⊞ Grid: On</button>
  <button class="toggle-btn" id="btn-outline">◎ Outline: Off</button>
</div>

<div id="canvas-wrapper">
  <canvas id="canvas" width="420" height="420"></canvas>
</div>

<div id="score-display">
  <div id="score-number">—</div>
  <div id="score-label">score</div>
  <div id="score-grade"></div>
  <div id="assist-note"></div>
</div>

<p id="instructions">Click and drag to draw your circle</p>
<button id="btn-retry">Try Again</button>

<script>
  const canvas = document.getElementById('canvas');
  const ctx = canvas.getContext('2d');
  const scoreNumber = document.getElementById('score-number');
  const scoreGrade = document.getElementById('score-grade');
  const assistNote = document.getElementById('assist-note');
  const instructions = document.getElementById('instructions');
  const btnRetry = document.getElementById('btn-retry');
  const btnGrid = document.getElementById('btn-grid');
  const btnOutline = document.getElementById('btn-outline');

  const W = canvas.width;
  const H = canvas.height;

  let drawing = false;
  let points = [];
  let showGrid = true;
  let showOutline = false;

  // Locked in at draw start so toggling mid-draw doesn't affect assist credit
  let usedGrid = false;
  let usedOutline = false;

  // ─── Toggles ───────────────────────────────────────────────
  btnGrid.addEventListener('click', () => {
    showGrid = !showGrid;
    btnGrid.textContent = showGrid ? '⊞ Grid: On' : '⊞ Grid: Off';
    btnGrid.classList.toggle('on', showGrid);
    if (!drawing) renderBackground();
  });

  btnOutline.addEventListener('click', () => {
    showOutline = !showOutline;
    btnOutline.textContent = showOutline ? '◎ Outline: On' : '◎ Outline: Off';
    btnOutline.classList.toggle('on', showOutline);
    if (!drawing) renderBackground();
  });

  // ─── Background (grid + outline) ──────────────────────────
  function renderBackground() {
    ctx.clearRect(0, 0, W, H);
    ctx.setLineDash([]);

    if (showGrid) {
      const step = 30;
      // Minor grid lines
      ctx.strokeStyle = '#181818';
      ctx.lineWidth = 1;
      for (let x = step; x < W; x += step) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
      }
      for (let y = step; y < H; y += step) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
      }
      // Center axes slightly brighter
      ctx.strokeStyle = '#222';
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(W/2, 0); ctx.lineTo(W/2, H); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, H/2); ctx.lineTo(W, H/2); ctx.stroke();
    }

    if (showOutline) {
      ctx.beginPath();
      ctx.arc(W/2, H/2, 130, 0, Math.PI * 2);
      ctx.strokeStyle = '#2c2c2c';
      ctx.lineWidth = 1;
      ctx.setLineDash([5, 7]);
      ctx.stroke();
      ctx.setLineDash([]);
    }
  }

  // ─── Input ─────────────────────────────────────────────────
  function getPos(e) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = W / rect.width;
    const scaleY = H / rect.height;
    if (e.touches) {
      return {
        x: (e.touches[0].clientX - rect.left) * scaleX,
        y: (e.touches[0].clientY - rect.top) * scaleY
      };
    }
    return {
      x: (e.clientX - rect.left) * scaleX,
      y: (e.clientY - rect.top) * scaleY
    };
  }

  function startDraw(e) {
    e.preventDefault();
    drawing = true;
    points = [];
    // Snapshot assist state at draw start
    usedGrid = showGrid;
    usedOutline = showOutline;
    points.push(getPos(e));
    renderBackground();
    instructions.textContent = 'Keep going…';
    scoreNumber.textContent = '—';
    scoreNumber.style.color = '#fff';
    scoreGrade.textContent = '';
    assistNote.textContent = '';
    btnRetry.style.display = 'none';
  }

  function moveDraw(e) {
    e.preventDefault();
    if (!drawing) return;
    points.push(getPos(e));
    redrawStroke();
  }

  function endDraw(e) {
    e.preventDefault();
    if (!drawing) return;
    drawing = false;
    if (points.length > 10) {
      showScore(computeScore());
    } else {
      instructions.textContent = 'Draw a bigger circle!';
    }
    btnRetry.style.display = 'inline-block';
  }

  canvas.addEventListener('mousedown', startDraw);
  canvas.addEventListener('mousemove', moveDraw);
  canvas.addEventListener('mouseup', endDraw);
  canvas.addEventListener('mouseleave', endDraw);
  canvas.addEventListener('touchstart', startDraw, { passive: false });
  canvas.addEventListener('touchmove', moveDraw, { passive: false });
  canvas.addEventListener('touchend', endDraw, { passive: false });

  // ─── Stroke rendering ──────────────────────────────────────
  function redrawStroke() {
    renderBackground();
    if (points.length < 2) return;
    ctx.beginPath();
    ctx.moveTo(points[0].x, points[0].y);
    for (let i = 1; i < points.length; i++) {
      ctx.lineTo(points[i].x, points[i].y);
    }
    ctx.strokeStyle = '#e8e8e8';
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.setLineDash([]);
    ctx.stroke();
  }

  // ─── Score computation ─────────────────────────────────────
  function computeScore() {
    // Step 1: rough centroid as starting guess
    let cx = 0, cy = 0;
    for (const p of points) { cx += p.x; cy += p.y; }
    cx /= points.length;
    cy /= points.length;

    // Step 2: iterative best-fit circle center (Karimäki-style gradient descent)
    // This finds the true geometric center regardless of where you drew,
    // so off-center circles aren't penalised vs centered ones.
    for (let iter = 0; iter < 10; iter++) {
      const radii = points.map(p => Math.hypot(p.x - cx, p.y - cy));
      const avgR = radii.reduce((a, b) => a + b, 0) / radii.length;
      let dx = 0, dy = 0;
      for (let i = 0; i < points.length; i++) {
        const r = radii[i];
        if (r < 0.001) continue;
        const w = (r - avgR) / r;
        dx += (cx - points[i].x) * w;
        dy += (cy - points[i].y) * w;
      }
      cx -= dx / points.length;
      cy -= dy / points.length;
    }

    // Step 3: final radii from best-fit center
    const radii = points.map(p => Math.hypot(p.x - cx, p.y - cy));
    const avgR = radii.reduce((a, b) => a + b, 0) / radii.length;

    // 1. CIRCULARITY — coefficient of variation of radii from best-fit center.
    //    Pure shape measure: size and position don't matter at all.
    const variance = radii.reduce((s, r) => s + (r - avgR) ** 2, 0) / radii.length;
    const cv = Math.sqrt(variance) / avgR;
    // cv of ~0.02 (2%) = quite good. Scale so that feels like ~75 points.
    const circularity = Math.max(0, 1 - cv * 4);

    // 2. CLOSURE — gap between first and last point, scaled by radius.
    // A gap of half the radius = 0 closure score.
    const first = points[0], last = points[points.length - 1];
    const gapRatio = Math.hypot(last.x - first.x, last.y - first.y) / avgR;
    const closure = Math.max(0, 1 - gapRatio * 2);

    // Circularity dominates; closure adds a fair deduction for open circles
    const raw = circularity * 0.80 + closure * 0.20;

    // Mild power curve to keep mid-range scores meaningful
    return Math.min(100, Math.round(Math.pow(raw, 1.3) * 100));
  }

  function getGrade(score) {
    if (score >= 95) return { text: '✦ PERFECT ✦', color: '#ffe066' };
    if (score >= 85) return { text: 'Outstanding',  color: '#a3e4a3' };
    if (score >= 72) return { text: 'Excellent',    color: '#a3e4a3' };
    if (score >= 58) return { text: 'Great',        color: '#aad4f5' };
    if (score >= 44) return { text: 'Not bad',      color: '#aad4f5' };
    if (score >= 30) return { text: 'Keep trying',  color: '#e8e8e8' };
    if (score >= 15) return { text: 'Rough',        color: '#e8a87c' };
    return               { text: 'Needs work',   color: '#e87c7c' };
  }

  function showScore(score) {
    const grade = getGrade(score);

    scoreNumber.textContent = score + '%';
    scoreNumber.style.color = grade.color;
    scoreGrade.textContent = grade.text;
    scoreGrade.style.color = grade.color;
    assistNote.textContent = '';

    instructions.textContent = 'Done! Draw again to retry.';

    // Ghost best-fit circle overlay
    let cx = 0, cy = 0;
    for (const p of points) { cx += p.x; cy += p.y; }
    cx /= points.length; cy /= points.length;
    const radii = points.map(p => Math.hypot(p.x - cx, p.y - cy));
    const avgR = radii.reduce((a, b) => a + b, 0) / radii.length;

    ctx.beginPath();
    ctx.arc(cx, cy, avgR, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(255,255,255,0.1)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 6]);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  // ─── Retry ─────────────────────────────────────────────────
  btnRetry.addEventListener('click', () => {
    points = [];
    renderBackground();
    scoreNumber.textContent = '—';
    scoreNumber.style.color = '#fff';
    scoreGrade.textContent = '';
    assistNote.textContent = '';
    instructions.textContent = 'Click and drag to draw your circle';
    btnRetry.style.display = 'none';
  });

  // Init
  renderBackground();
</script>

</body>
</html>
